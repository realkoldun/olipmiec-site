# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=root
DB_PASSWORD=password
DB_NAME=root

# Telegram (Scraper - без бота!)
# Укажите ID публичного канала (без @)
# Например: olimpiyec или t.me/olimpiyec
TELEGRAM_CHANNEL_ID=olimpiets2013

# Sync settings (in seconds)
TELEGRAM_SYNC_INTERVAL=300

# Ollama AI (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3001
